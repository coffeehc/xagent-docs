{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Audit Result",
  "type": "object",
  "required": [
    "status",
    "checks"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summary": {
      "type": "string"
    }
  }
}