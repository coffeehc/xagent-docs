{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim Map Entry",
  "type": "object",
  "required": [
    "claim_id",
    "section",
    "claim",
    "claim_type",
    "evidence_ids",
    "confidence"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^C[0-9]{4,}$"
    },
    "section": {
      "type": "string"
    },
    "claim": {
      "type": "string"
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "fact",
        "numeric",
        "estimate",
        "interpretation",
        "recommendation"
      ]
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "limitations": {
      "type": [
        "string",
        "null"
      ]
    },
    "requires_citation": {
      "type": "boolean"
    }
  }
}